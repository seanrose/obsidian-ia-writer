{
	"name": "obsidian-ia-writer",
	"version": "0.3.0",
	"description": "Open notes in iA Writer from Obsidian. Supports commands, context menus, and a ribbon icon.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"ia-writer",
		"markdown",
		"writing"
	],
	"author": "Sean Rose",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/seanrose/obsidian-ia-writer"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"obsidian": "latest",
		"tslib": "^2.7.0",
		"typescript": "^5.6.0"
	}
}
